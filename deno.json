{
  "version": "0.2.0",
  "exclude": ["slidedown"],
  "tasks": {
    "dev": "deno run --allow-net --allow-read jsr:@std/http/file-server static",
    "test": "deno test --allow-read",
    "check": "deno check src/sanitize.test.ts src/decode.test.ts src/rest.test.ts src/handoff.test.ts src/palette.test.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "exclude": ["static/**/*.html"]
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  }
}
